	<div id="modal_overlay" onClick="ModalClose();"></div>
	<div id="modal_outer">
	<div id="modal" tabindex="0">
	</div>
	</div>
	<div id="modal_dialog" style="display:none;"></div>
	<script type="text/javascript">
	jQuery(window).bind('resize.modal', ModalCentre);
	</script>
