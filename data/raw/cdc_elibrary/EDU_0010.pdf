                    <script type="text/javascript">
        var resizeTimer;
        myLayout=jQuery('body').layout(
            {
            livePaneResizing:true,
            triggerEventsDuringLiveResize: false,
            resizerTip: 'Resize',

            east__spacing_open:0,
            east__spacing_closed:8,
            east_resizable: true,
            east__closable: false,
            east__size: 295,

