        <!-- page 1 -->
        <string id="p1text1">Let’s learn to add three numbers!</string>
        <string id="p1text2">I have 6 sweets.</string>
        <string id="p1text3">Sagar gave me 5 sweets.</string>
        <string id="p1text4">Numa gave me 7 more sweets.</string>
        <string id="p1text5">How many sweets do I have now?</string>
        <string id="p1text6">Let’s count all the sweets.</string>
        <string id="p1text7">I have 18 sweets now.</string>
        <string id="p1text8"><![CDATA[Let’s read aloud! <br/> 6 + 5 + 7 = 18]]></string>


