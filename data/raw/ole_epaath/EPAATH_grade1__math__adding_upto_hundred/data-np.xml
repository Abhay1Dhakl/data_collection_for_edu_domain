        <string id='it_is_more_than'>त्यो भन्दा बाढी हुन्‍छ। दायाँबाट बायाँ गएर गणना गरौँ।</string>

        <!-- page 1 -->
        <string id="p1text1">१०० सम्म आउने सङ्ख्याहरूको जोड गरौँ।</string>
        <string id="p1text2">ऊषासँग ३० ओटा गुच्‍चाहरू छन्।</string>
        <string id="p1text3">नूमासँग ४० ओटा गुच्‍चाहरू छन्।</string>
        <string id="p1text4">अब जम्मा कतिओटा गुच्‍चाहरू छन्?</string>
        <string id="p1text4_a">३०</string>
        <string id="p1text4_b">४०</string>
        <string id="p1text4_opt_a">२०</string>
        <string id="p1text4_opt_b">७०</string>
        <string id="p1text4_opt_c">८०</string>
        <string id="p1text5">सुरुमा, ० + ० ‍‍= ० हुन्‍छ।</string>
        <string id="p1text6">त्‍यसपछि, ३ + ४ = ७ हुन्‍छ।</string>
        <string id="p1text7">उनीहरूसँग जम्मा ७० ओटा गुच्‍चाहरू छन्।</string>

        <!-- page 2 -->
        <string id="p2text1">मेरा दाइ र दिदीसँग केहि चकलेटहरू छन्।</string>
        <string id="p2text2">मेरा दाइसँग २५ ओटा चकलेटहरू छन्।</string>
        <string id="p2text3">मेरि दिदीसँग ३३ ओटा चकलेटहरू छन्।</string>
        <string id="p2text4">उहाँहरूसँग जम्‍मा कति ओटा चकलेटहरू छन्?</string>
        <string id="p2text4_a">२५</string>
        <string id="p2text4_b">३३</string>
        <string id="p2text4_opt_a">५१</string>
        <string id="p2text4_opt_b">५८</string>
        <string id="p2text4_opt_c">७८</string>
        <string id="p2text5">सुरुमा, ५ + ३ ‍‍= ८ हुन्‍छ।</string>
        <string id="p2text6">त्‍यसपछि, २ + ३ = ५ हुन्‍छ।</string>
        <string id="p2text7">उहाँहरूसँग जम्‍मा ५८ ओटा चकलेटहरू छन्।</string>

        <!--page3.html-->
        <string id="p3text1">अब केहि थप जोडहरू गरौँ।</string>
        <string id="p3text2">४ ‌+ १२ कति हुन्‍छ?</string>
        <string id="p3text2_a">०४</string>
        <string id="p3text2_b">१२</string>
        <string id="p3text2_opt_a">१३</string>
        <string id="p3text2_opt_b">१६</string>
        <string id="p3text2_opt_c">५६</string>
        <string id="p3text2_ans_a">सुरुमा, ४ + २ ‍‍= ६ हुन्‍छ।</string>
        <string id="p3text2_ans_b">त्‍यसपछि, ० + १ = १ हुन्‍छ।</string>
        <string id="p3text3">७२ ‌+ ३ कति हुन्‍छ?</string>
        <string id="p3text4_a">७२</string>
        <string id="p3text4_b">०३</string>
        <string id="p3text3_opt_a">४५</string>
        <string id="p3text3_opt_b">७५</string>
        <string id="p3text3_opt_c">७८</string>
        <string id="p3text3_ans_a">सुरुमा, २ + ३ ‍‍= ५ हुन्‍छ।</string>
        <string id="p3text3_ans_b">त्‍यसपछि, ७ + ० = ७ हुन्‍छ।</string>


