        <string id="p1text4_a">30</string>
        <string id="p1text4_b">40</string>
        <string id="p1text4_opt_a">20</string>
        <string id="p1text4_opt_b">70</string>
        <string id="p1text4_opt_c">80</string>
        <string id="p1text5">First, 0+0=0</string>
        <string id="p1text6">And then, 3+4=7</string>
        <string id="p1text7">They have 70 marbles in total.</string>

