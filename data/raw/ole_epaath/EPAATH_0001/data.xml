<!-- page 1 -->
	<string id="p1text1">How many sweets are here?</string>
	<string id="p1text2">Let us find half of 18 or the result of multiplying ::1_/_2;; with 18.</string>
	<string id="p1text3">18 × ::1_/_2;; = ::1 × 18_/_2;; = ::18_/_2;; =</string>
	<string id="p1text4">Now, let us find one third of 18 or the result of multiplying ::1_/_3;; with 18.</string>
	<string id="p1text5">18 × ::1_/_3;; = ::1 × 18_/_3;; = ::18_/_3;; =</string>
	<string id="p1text6">Multiplying a fraction with a whole number means multiplying the whole number with the numerator keeping denominator the same. </string>
	<string id="p1text7">5 × ::1_/_3;; = ::5 × 1_/_3;; = ::5_/_3;;</string>
	<string id="p1text8">If the result is improper, then it should be converted into mixed fraction.</string>
	<string id="p1text9">::5_/_#3@;; = ::#3@ + 2_/_#3@;;</string>
	<string id="p1text10">::5_/_3;; = ::#3@ + 2_/_#3@;; = ::#3@_/_#3@;; + ::2_/_#3@;;</string>
	<string id="p1text11">::5_/_3;; = ::3 + 2_/_3;; = ::#3@_/_#3@;; + ::2_/_#3@;; = #1@ + ::2_/_#3@;;</string>
	<string id="p1text12">::5_/_3;; = ::3 + 2_/_3;; = ::3_/_3;; + ::2_/_3;; = #1@ + ::2_/_#3@;; =  #1@::2_/_#3@;;</string>
	<string id="p1text13">::5_/_3;; also means 5 ÷ 3:</string>
	<string id="p1text14">Let us multiply ::1_/_3;; with 14.</string>
	<string id="p1text15">14 × ::1_/_3;; = ::1 × 14_/_3;; = ::14_/_3;; = ::3 + 3 + 3 + 3 + 2_/_3;; = </string>
	<string id="p1text16">::5_/_3;;</string>
<!--page 1 end-->

