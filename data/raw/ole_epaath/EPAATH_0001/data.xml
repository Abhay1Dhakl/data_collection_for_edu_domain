<!-- page 3 -->
	<string id="p3text1">Multiplying a fraction with another fraction means multiplying the numerator with the numerator and denominator with the denominator.</string>
	<string id="p3text2">::2_/_3;; × ::1_/_5;; = ::2 × 1_/_3 × 5;; = ::2_/_15;;</string>
	<string id="p3text3">Enter two proper fractions you want to multiply:</string>
	<string id="p3text4">Choose a numerator which is less than the denominator.</string>
	<string id="p3text5">::2_/_3;; × ::1_/_5;; = </string>
	<string id="p3text6">::2_/_3;; × ::1_/_5;; = </string>
<!--page 3 end-->

